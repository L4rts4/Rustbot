const { SlashCommandBuilder, EmbedBuilder } = require('discord.js');

module.exports = {
  data: new SlashCommandBuilder()
    .setName('tiimi')
    .setDescription('Näyttää tiimin jäsenten statuksen'),
  async execute(interaction) {
    const embed = new EmbedBuilder()
      .setColor(0xCE3720)
      .setTitle('👥 Tiimin Status')
      .setDescription('⚠️ Rust+ yhteyttä ei ole vielä määritetty.')
      .setFooter({ text: 'Lisää Rust+ token .env tiedostoon' })
      .setTimestamp();
    await interaction.reply({ embeds: [embed] });
  }
};
